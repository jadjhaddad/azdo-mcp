# Azure DevOps organisation URL (required)
# e.g. https://dev.azure.com/my-org
AZDO_ORG_URL=https://dev.azure.com/my-org

# Personal Access Token — needs vso.work scope (or vso.work_write for writes)
# Injected by host/backend; never commit real tokens.
AZDO_TOKEN=

# Comma-separated list of project names this server is allowed to touch
# Leave empty to allow all projects accessible by the token (not recommended)
AZDO_ALLOWED_PROJECTS=ProjectA,ProjectB

# Default project used when caller omits project filter
AZDO_DEFAULT_PROJECT=

# Enable delete_ticket tool (false by default — explicit opt-in required)
ENABLE_DELETE=false

# Maximum page size for list/search operations (default 200)
MAX_PAGE_SIZE=200

# Log level: trace | debug | info | warn | error (default info)
LOG_LEVEL=info

# MCP server name (shown to clients)
SERVER_NAME=azdo-mcp

# MCP server version
SERVER_VERSION=0.1.0
